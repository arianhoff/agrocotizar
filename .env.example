# ─── Supabase ─────────────────────────────────────────────────────────────────
# Obtené estos valores en: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-public

# ─── Netlify Environment Variables (servidor únicamente) ──────────────────────
# Configurar en: Netlify → Site settings → Environment variables
# NUNCA en .env local — estas variables viven solo en el servidor

# Anthropic (IA — extracción de catálogos, cotizador por voz)
ANTHROPIC_API_KEY=sk-ant-...

# AFIP / ARCA — Padrón contribuyentes
# Obtené el certificado y clave desde el portal de AFIP
AFIP_CUIT=20000000000
AFIP_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
AFIP_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# "prod" para producción, cualquier otro valor (o vacío) usa homologación
AFIP_ENV=prod

# Supabase service-side (para verificar JWT en funciones Netlify)
# Mismos valores que VITE_SUPABASE_URL/ANON_KEY — se leen sin prefijo VITE_
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-public
# Service role key — para la caché del token AFIP (Netlify únicamente, NUNCA en frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
