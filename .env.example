# Supabase - get from https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API key — servidor únicamente, nunca expuesta al browser
# En Netlify: Site settings → Environment variables → ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=sk-ant-...

# Contraseña de acceso a la app (build time — se incluye en el bundle)
# Cambiala antes de cada deploy si querés mayor seguridad
VITE_APP_PASSWORD=agrocotizar2026
